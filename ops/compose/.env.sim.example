# Tempo devnet simulation env. Copy to `.env` and fill in. NEVER use a mainnet RPC.

# --- shared (all services) ---
TEMPO_RPC_URL=https://api.devnet.solana.com
# After `provision`, copy these out of ./artifact/sim-artifact.json:
TEMPO_MARKET=
# Only for a money-path market (TEMPO_SIM_MAINT_BPS > 0 at provision time):
TEMPO_COLLATERAL_MINT=

# --- provisioner (used by the `provision` one-shot service) ---
# The master keypair funds + creates everything (and is the collateral mint authority).
TEMPO_SIM_MASTER_KEYPAIR=/keys/master.json
TEMPO_SIM_NUM_TRADERS=12
TEMPO_SIM_NUM_MM=2
# Phase A (clearing-only): leave MAINT_BPS=0. Phase B (positions/liquidations): set it.
TEMPO_SIM_MAINT_BPS=0
# TEMPO_SIM_INITIAL_BPS=1000      # >= MAINT; defaults to MAINT
# TEMPO_SIM_PENALTY_BPS=100
TEMPO_SIM_TICK_SIZE=10000000      # $0.10 in 1e8 units
TEMPO_SIM_NUM_TICKS=256
TEMPO_SIM_CAP=128
# TEMPO_SIM_DEPOSIT=1000000000000000   # collateral minted+deposited per agent (Phase B)
TEMPO_SIM_FUND_LAMPORTS=50000000  # SOL (lamports) sent to each agent for rent + fees

# --- trader knobs (per container; persona/seed are set inline in compose) ---
TEMPO_SIM_POLL_MS=800
TEMPO_SIM_BASE_SIZE=5
TEMPO_SIM_AGGRESSION_TICKS=2
TEMPO_SIM_INNER_SPREAD_TICKS=1
TEMPO_SIM_MAX_ORDERS=3
