# Copy to .env (git-ignored) and fill in. Shared by every service in the stack.
#
# DEVNET ONLY. Use a devnet RPC here. Never point the bot services at mainnet
# (the mainnet pool stays commented out — see CLAUDE.md).
TEMPO_RPC_URL=https://api.devnet.solana.com
# TEMPO_RPC_URL=https://mainnet.helius-rpc.com/...   # DO NOT enable for bots.

# Markets the keeper cranks and the liquidator scans. The liquidator takes a
# comma-separated list (cross accounts span markets); the keeper/mm-bot use the
# first via TEMPO_MARKET.
TEMPO_MARKETS=REPLACE_WITH_MARKET_PUBKEY
TEMPO_MARKET=REPLACE_WITH_MARKET_PUBKEY

# Collateral mint (drives the vault PDA + the money path). Optional for a pure
# clearing-only market.
TEMPO_COLLATERAL_MINT=REPLACE_WITH_COLLATERAL_MINT

# Confirmation commitment for reads/sends.
TEMPO_COMMITMENT=confirmed

# Priority fee in micro-lamports prepended to every transaction.
# 0 = omit the price instruction (devnet/local default).
# Set to >=1000 on mainnet to compete for block space.
# Example: 10000 = ~0.001 SOL per tx at 200k CU.
TEMPO_PRIORITY_FEE_MICRO_LAMPORTS=0

# --- optional cadence overrides (sane defaults baked into each service) ---
# TEMPO_CRANK_POLL_MS=800
# TEMPO_FUNDING_INTERVAL_SECS=60
# TEMPO_LIQ_POLL_MS=2000
# TEMPO_LIQ_CONCURRENCY=8
# TEMPO_LIQ_STALE_SCAN_SECS=30
# TEMPO_API_POSITION_POLL_MS=5000

# Each service's keypair path is set per-service in docker-compose.yml
# (/keys/<name>.json, a read-only mount). Keys are NEVER baked into an image.
