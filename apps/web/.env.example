# Tempo web dApp — devnet only. Copy to .env.local and fill in.

# Devnet JSON-RPC endpoint (defaults to https://api.devnet.solana.com if unset).
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Market PDA to load on startup (a devnet SOL/USD Tempo market). See README "Demo setup".
NEXT_PUBLIC_TEMPO_MARKET=

# SPL mint used as collateral (e.g. a devnet USDC mint). Drives the faucet hint and deposit path.
NEXT_PUBLIC_COLLATERAL_MINT=

# Program vault's token account for the collateral mint (required to deposit/withdraw).
NEXT_PUBLIC_VAULT_TOKEN_ACCOUNT=

# Your wallet's token account for the collateral mint (defaults to the connected wallet's ATA if blank).
NEXT_PUBLIC_USER_TOKEN_ACCOUNT=

# Optional dev-only burner wallet: set to 1 to sign in-page with a local keypair (NEVER on mainnet).
NEXT_PUBLIC_USE_BURNER=
# Burner secret key as a JSON byte array (Solana id.json contents) or a base58 string. Dev-only.
NEXT_PUBLIC_BURNER_SECRET=
